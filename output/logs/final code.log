. /* 2. data clean programs */
. /* 2.1 clean program for datasets from world bank */
. capture program drop clean_wb

. program define clean_wb
  1.     syntax using/, OUTfile(string) VARNAME(string)
  2. 
.     import delimited using `"`using'"', varnames(nonames) clear stringcols(_all)
  3. 
.     * World Bank downloads have column labels in the first row when imported
.     drop in 1
  4. 
.     rename v3 country
  5.     rename v4 code
  6.     drop v1 v2
  7.     drop if missing(code)
  8. 
.     local start_year = 1960
  9.     local end_year   = 2025
 10.     local first_col  = 5
 11.     local last_col   = `first_col' + (`end_year' - `start_year')
 12. 
.     local yr = `start_year'
 13.     forvalues j = `first_col'/`last_col' {
 14.         capture confirm variable v`j'
 15.         if !_rc {
 16.             rename v`j' y`yr'
 17.             local ++yr
 18.         }
 19.     }
 20.         /* reshape dataset */
.     reshape long y, i(code) j(year)
 21.     rename y `varname'
 22.     replace `varname' = "" if `varname' == ".."
 23.     destring `varname', replace force
 24. 
.     keep country code year `varname'
 25.     order country code year `varname'
 26.     sort code year
 27.     isid code year
 28.     save `"`outfile'"', replace
 29. end

. 
. /* 2.2 clean program for democracy index dataset */
. capture program drop clean_dem

. program define clean_dem
  1.     syntax using/, OUTfile(string) PRIORITY(integer)
  2. 
.     import delimited using `"`using'"', varnames(1) case(lower) clear
  3. 
.     rename entity country
  4.     destring year, replace force
  5.     destring democracy, replace force
  6.     drop if missing(code)
  7. 
.     gen source_priority = `priority'
  8.     keep country code year democracy source_priority
  9.     order country code year democracy source_priority
 10.     sort code year source_priority
 11.     save `"`outfile'"', replace
 12. end

